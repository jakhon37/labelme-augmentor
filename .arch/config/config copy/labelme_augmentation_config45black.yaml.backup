# Validation settings
validation:
  enabled: true
  
  # Minimum defect area after augmentation (in pixels)
  min_defect_area: 20
  
  # Maximum defect area (to filter out artifacts)
  max_defect_area: null  # null = no limit
  
  # Minimum number of contour points
  min_contour_points: 3
  
  # Check if augmentation significantly changed the defect
  check_defect_preservation: true
  max_area_change_ratio: 0.5  # Reject if area changed more than 50%
  
  # Reject augmentations where defects touch image border
  reject_border_defects: false
  border_margin: 5  # pixels

# Color palette for visualization
visualization:
  auto_generate_colors: true  # Generate unlimited colors
  custom_colors:  # Optional: define specific colors for classes
    # Format: [R, G, B]
    Scratch: [255, 0, 0]
    Discoloration: [0, 255, 0]
    SmallDot: [0, 0, 255]
  default_colors:
    - [255, 0, 0]    # Red
    - [0, 255, 0]    # Green
    - [0, 0, 255]    # Blue
    - [255, 255, 0]  # Yellow
    - [255, 0, 255]  # Magenta
    - [0, 255, 255]  # Cyan
    - [128, 0, 0]    # Maroon
    - [0, 128, 0]    # Dark Green
    - [0, 0, 128]    # Navy
    - [128, 128, 0]  # Olive

# Image format handling
image_processing:
  # Supported input formats
  supported_formats: ['.jpg', '.jpeg', '.png', '.bmp', '.tiff', '.tif']
  
  # Output format
  output_format: 'png'  # 'png', 'jpg', etc.
  output_quality: 95  # For JPEG
  
  # Handle different bit depths
  normalize_16bit: true  # Convert 16-bit to 8-bit
  
  # Handle different color spaces
  convert_to_rgb: true
  
  # Handle different channel counts
  handle_grayscale: true  # Convert to RGB
  handle_rgba: true  # Remove alpha channel
  
  # Image validation
  validate_loaded_images: true
  min_image_size: [448, 448]  # [width, height]
  max_image_size: [640, 640]
